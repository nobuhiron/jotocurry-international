---
import Layout from '../../layouts/Layout.astro';
import SectionPageHero from '../../sections/SectionPageHero.astro';
import SectionContactForm from '../../sections/SectionContactForm.astro';
import SectionContactFaq from '../../sections/SectionContactFaq.astro';
import { translations } from '../../data/translations';
import type { Locale } from '../../lib/i18n';

const contactHeroImageUrl =
  'https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?auto=format&fit=crop&w=1920&q=80';

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { lang: 'ja' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const locale = (lang as Locale) || 'ja';
const contactPageText = translations.contact.page[locale];
const metaText = translations.meta[locale];
---

<Layout title={contactPageText.title} description={metaText.contact.description} canonicalPath={`/${locale}/contact`} locale={locale}>
		<SectionPageHero
			title={contactPageText.heroTitle}
			subtitle={contactPageText.heroSubtitle}
			backgroundImage={contactHeroImageUrl}
		/>
	<SectionContactForm locale={locale} />
	<SectionContactFaq locale={locale} />
</Layout>
