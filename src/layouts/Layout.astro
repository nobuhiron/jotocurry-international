---
import '../styles/style.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import CtaSection from './CtaSection.astro';
import type { Locale } from '../lib/i18n';

interface Props {
  title: string;
  locale?: Locale;
  description?: string;
  canonicalPath?: string;
}

const { title, locale = 'ja', description, canonicalPath } = Astro.props;
const htmlLang = locale === 'en' ? 'en' : 'ja';
const siteUrl = Astro.url.origin;
const siteName = locale === 'en' ? 'Joto Curry' : '上等カレー';
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : Astro.url.href;
const altLocale = locale === 'en' ? 'ja' : 'en';
const altPath = canonicalPath ? canonicalPath.replace(`/${locale}/`, `/${altLocale}/`) : Astro.url.pathname.replace(`/${locale}/`, `/${altLocale}/`);
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@600;700&family=Noto+Sans+JP:wght@400;500&family=Roboto:wght@400;500;700&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@600;700&family=Noto+Sans+JP:wght@400;500&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@600;700&family=Noto+Sans+JP:wght@400;500&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet"></noscript>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={altLocale} href={`${siteUrl}${altPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${canonicalPath ? canonicalPath.replace(`/${locale}/`, '/ja/') : Astro.url.pathname.replace(`/${locale}/`, '/ja/')}`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'ja_JP'} />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <title>{title}</title>
  </head>
  <body class="l-body">
    <a href="#main-content" class="skip-to-main">
      {locale === 'en' ? 'Skip to main content' : 'メインコンテンツへスキップ'}
    </a>
    <Header locale={locale} />
    <main class="l-main" id="main-content">
      <slot />
    </main>
    <CtaSection locale={locale} />
    <Footer locale={locale} />
  </body>
</html>
