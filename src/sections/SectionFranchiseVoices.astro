---
import SectionTitle from '../components/SectionTitle.astro';
import { optimizeImageUrl } from '../lib/microcms';
import { translations } from '../data/translations';
import { getTestimonials } from '../lib/microcms-testimonials';
import { getLocalizedTestimonial } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'ja' } = Astro.props;
const voicesText = translations.franchise.voices[locale];

// microCMSからフランチャイズボイスを取得（失敗時はセクションを非表示）
function textToParagraphs(text: string): string[] {
  return text.split(/\n+/).map((p) => p.trim()).filter(Boolean);
}

let testimonials: Array<{ paragraphs: string[]; storeName: string; image?: { url: string; width: number; height: number } }> = [];
let showSection = false;
try {
  const testimonialsData = await getTestimonials(locale);
  if (testimonialsData.length > 0) {
    testimonials = testimonialsData.map((testimonial) => {
      const { text, storeName } = getLocalizedTestimonial(testimonial, locale);
      return {
        paragraphs: textToParagraphs(text),
        storeName,
        image: testimonial.image,
      };
    });
    showSection = true;
  }
} catch (error) {
  console.warn('microCMSからフランチャイズボイスを取得できませんでした。セクションを非表示にします。', error);
}
---

{showSection && (
  <>
    <section class="p-franchise-voices l-section" data-bg="white" id="section-franchise-voices">
  <div class="l-container">
    <div class="p-franchise-voices__inner l-section__inner">
      <SectionTitle
        title={voicesText.title}
        subtitle={voicesText.subtitle}
        class="p-franchise-voices__title"
        align="center"
      />
    </div>
  </div>
  <div class="p-franchise-voices__carousel-wrapper">
    <div class="p-franchise-voices__carousel splide" id="franchise-voices-carousel" aria-label={locale === 'en' ? 'Franchise owner testimonials' : 'フランチャイズオーナーの声'} aria-roledescription={locale === 'en' ? 'carousel' : 'カルーセル'}>
      <div class="splide__track">
        <ul class="splide__list">
          {testimonials.map((testimonial) => (
            <li class="splide__slide">
              <div class="p-franchise-voices__slide">
                <div class="p-franchise-voices__profile">
                  <div class="p-franchise-voices__avatar" aria-hidden="true">
                    {testimonial.image ? (
                      <img
                        src={optimizeImageUrl(testimonial.image.url, 200)}
                        srcset={`${optimizeImageUrl(testimonial.image.url, 96)} 96w, ${optimizeImageUrl(testimonial.image.url, 200)} 200w`}
                        sizes="96px"
                        alt={testimonial.storeName}
                        width={96}
                        height={96}
                        loading="lazy"
                        decoding="async"
                        class="p-franchise-voices__avatar-img"
                      />
                    ) : (
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <circle cx="18" cy="6" r="4" opacity="0.7"/>
                        <path d="M2 20L8 12L14 16L20 10V20H2Z" opacity="0.5"/>
                      </svg>
                    )}
                  </div>
                  <p class="p-franchise-voices__store-name">{testimonial.storeName}</p>
                </div>
                <div class="p-franchise-voices__paragraphs">
                  {(testimonial.paragraphs ?? []).map((paragraph) => (
                    <p class="p-franchise-voices__text">{paragraph}</p>
                  ))}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
    </section>
    <script>
      import initFranchiseVoices from '../scripts/franchise-voices.js';

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFranchiseVoices);
      } else {
        initFranchiseVoices();
      }
    </script>
  </>
)}

