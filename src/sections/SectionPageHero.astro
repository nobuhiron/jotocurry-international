---
import Image from 'astro/components/Image.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle: string;
  backgroundImage?: ImageMetadata | string;
}

const { title, subtitle, backgroundImage } = Astro.props;
---

<section class="p-page-hero">
  {backgroundImage && (
    <div class="p-page-hero__image" aria-hidden="true">
      {typeof backgroundImage === 'string' ? (
        <img
          src={backgroundImage}
          alt=""
          width="3840"
          height="2160"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          referrerpolicy="no-referrer"
        />
      ) : (
        <Image
          src={backgroundImage}
          alt=""
          width={3840}
          height={2160}
          widths={[960, 1920, 3840]}
          sizes="100vw"
          format="webp"
          loading="eager"
          fetchpriority="high"
        />
      )}
    </div>
  )}
  <div class="p-page-hero__background" aria-hidden="true"></div>
  <div class="l-container">
    <div class="p-page-hero__inner">
      <h1 class="p-page-hero__title">{title}</h1>
      <p class="p-page-hero__subtitle" set:html={subtitle}></p>
    </div>
  </div>
</section>
