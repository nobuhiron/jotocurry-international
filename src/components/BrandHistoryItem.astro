---
import type { ImageMetadata } from 'astro';
import Image from 'astro/components/Image.astro';

interface Props {
  year: string;
  heading: string;
  description: string;
  imageSrc: ImageMetadata;
  imageAlt?: string;
}

const { year, heading, description, imageSrc, imageAlt = '' } = Astro.props;
---

<div class="p-brand-history__item">
  <div class="p-brand-history__item-header">
    <div class="p-brand-history__item-year">{year}</div>
  </div>
  <div class="p-brand-history__item-content" style="padding-inline-start: var(--spacing-lg);">
    <div class="p-brand-history__item-image">
      <Image
      src={imageSrc}
      alt={imageAlt}
      width={1000}
      height={750}
      widths={[600, 1000]}
      sizes="(min-width: 1024px) 600px, 100vw"
      format="webp"
      loading="lazy"
      class="p-brand-history__item-image-img"
    />
    </div>
    <div class="p-brand-history__item-text">
      <h3 class="p-brand-history__item-heading" set:html={heading}></h3>
      <p class="p-brand-history__item-description">{description}</p>
    </div>
  </div>
</div>

