---
import type { Locale } from '../lib/i18n';
import { getLocalizedPath } from '../lib/i18n';

interface Props {
  currentLocale: Locale;
  currentPath: string;
  locale?: Locale;
}

const { currentLocale, currentPath, locale = currentLocale } = Astro.props;

const languages = [
  { code: 'ja' as Locale, label: '日本語' },
  { code: 'en' as Locale, label: 'English' },
];

const labels = locale === 'en'
  ? { selectLanguage: 'Select language' }
  : { selectLanguage: '言語を選択' };

const switcherId = `language-switcher-${Math.random().toString(36).slice(2, 9)}`;
const dropdownId = `${switcherId}-dropdown`;
---

<div class="c-language-switcher" data-language-switcher={switcherId}>
  <button
    class="c-language-switcher__toggle"
    type="button"
    aria-expanded="false"
    aria-controls={dropdownId}
    aria-label={labels.selectLanguage}
  >
    <span class="c-language-switcher__current">
      {languages.find((lang) => lang.code === currentLocale)?.label || '日本語'}
    </span>
    <span class="c-language-switcher__icon" aria-hidden="true">▼</span>
  </button>
  <div class="c-language-switcher__dropdown" id={dropdownId}>
    <ul class="c-language-switcher__list">
      {languages.map((lang) => {
        const isActive = lang.code === currentLocale;
        const localizedPath = getLocalizedPath(currentPath, lang.code);
        return (
          <li class="c-language-switcher__item">
            <a
              href={localizedPath}
              class={`c-language-switcher__link ${isActive ? 'is-active' : ''}`}
              data-lang={lang.code}
              aria-current={isActive ? 'page' : undefined}
            >
              {lang.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</div>

<style>
  .c-language-switcher {
    position: relative;
  }

  .c-language-switcher__toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid currentColor;
    border-radius: 4px;
    color: inherit;
    cursor: pointer;
    font-size: inherit;
    font-family: inherit;
  }

  .c-language-switcher__toggle:hover {
    opacity: 0.8;
  }

  .c-language-switcher__icon {
    font-size: 0.75em;
  }

  .c-language-switcher__dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.5rem;
    min-width: 120px;
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    z-index: 1002;
  }

  .c-language-switcher__toggle[aria-expanded="true"] + .c-language-switcher__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* モバイルメニュー内はトグル直下に表示して、画面外にはみ出さないようにする */
  .l-header__mobile-language .c-language-switcher__dropdown {
    top: calc(100% + 0.5rem);
    right: 0;
    left: auto;
    margin-top: 0;
    margin-left: 0;
    min-width: 100%;
    transform: translateY(-10px);
  }

  .l-header__mobile-language
    .c-language-switcher__toggle[aria-expanded='true']
    + .c-language-switcher__dropdown {
    transform: translateY(0);
  }

  .c-language-switcher__list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
  }

  .c-language-switcher__item {
    margin: 0;
  }

  .c-language-switcher__link {
    display: block;
    padding: 0.5rem 1rem;
    color: inherit;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .c-language-switcher__link:hover {
    background-color: #f5f5f5;
  }

  .c-language-switcher__link.is-active {
    background-color: #f0f0f0;
    font-weight: 500;
  }
</style>

<script is:inline>
  (function () {
    const switchers = document.querySelectorAll('.c-language-switcher');
    if (switchers.length === 0) return;

    function getFocusableLinks(switcher) {
      return Array.from(switcher.querySelectorAll('.c-language-switcher__link'));
    }

    function setOpenState(toggle, dropdown, isOpen) {
      toggle.setAttribute('aria-expanded', String(isOpen));
    }

    function closeAll(exceptToggle) {
      document.querySelectorAll('.c-language-switcher').forEach((switcher) => {
        const toggle = switcher.querySelector('.c-language-switcher__toggle');
        const dropdown = switcher.querySelector('.c-language-switcher__dropdown');
        if (!toggle || !dropdown || toggle === exceptToggle) return;
        setOpenState(toggle, dropdown, false);
      });
    }

    switchers.forEach((switcher) => {
      if (switcher.dataset.initialized === 'true') return;
      switcher.dataset.initialized = 'true';

      const toggle = switcher.querySelector('.c-language-switcher__toggle');
      const dropdown = switcher.querySelector('.c-language-switcher__dropdown');
      if (!toggle) return;
      if (!dropdown) return;

      toggle.addEventListener('click', (event) => {
        event.preventDefault();
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        closeAll(toggle);
        setOpenState(toggle, dropdown, !isOpen);
      });

      toggle.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowDown') return;
        event.preventDefault();
        closeAll(toggle);
        setOpenState(toggle, dropdown, true);
        const links = getFocusableLinks(switcher);
        if (links.length > 0) {
          links[0].focus();
        }
      });

      dropdown.addEventListener('keydown', (event) => {
        const links = getFocusableLinks(switcher);
        if (links.length === 0) return;

        if (event.key === 'Escape') {
          event.preventDefault();
          setOpenState(toggle, dropdown, false);
          toggle.focus();
          return;
        }

        const currentIndex = links.findIndex((link) => link === document.activeElement);
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          const nextIndex = currentIndex >= 0 ? (currentIndex + 1) % links.length : 0;
          links[nextIndex].focus();
        } else if (event.key === 'ArrowUp') {
          event.preventDefault();
          const prevIndex = currentIndex > 0 ? currentIndex - 1 : links.length - 1;
          links[prevIndex].focus();
        } else if (event.key === 'Tab') {
          setOpenState(toggle, dropdown, false);
        }
      });
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!target) return;
      if (!target.closest('.c-language-switcher')) {
        closeAll();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeAll();
      }
    });
  })();
</script>
