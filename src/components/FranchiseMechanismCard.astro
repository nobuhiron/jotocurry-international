---
interface Props {
  icon: string;
  title: string;
  paragraphs: string[];
  class?: string;
}

const { icon, title, paragraphs, class: className = '' } = Astro.props;
---

<div class={`c-franchise-mechanism-card ${className}`}>
  <div class="c-franchise-mechanism-card__header">
    <div class="c-franchise-mechanism-card__icon" aria-hidden="true" set:html={icon} />
    <h3 class="c-franchise-mechanism-card__title">{title}</h3>
  </div>
  <div class="c-franchise-mechanism-card__paragraphs">
    {(paragraphs ?? []).map((paragraph) => (
      <p class="c-franchise-mechanism-card__description">{paragraph}</p>
    ))}
  </div>
</div>

