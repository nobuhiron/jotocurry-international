{
  "name": "astro-starter",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "optimize:images": "node scripts/optimize-cta-bg.mjs",
    "prebuild": "pnpm optimize:images",
    "preview": "astro preview",
    "astro": "astro",
    "check:type": "astro check",
    "check:build": "astro build",
    "check:css": "stylelint \"src/styles/**/*.css\"",
