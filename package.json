    "check:delivery": "pnpm check:local",
    "preflight": "pnpm check:delivery"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@splidejs/splide": "^4.1.4",
